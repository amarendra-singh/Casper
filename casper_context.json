  "pricing_formula": {
    "steps": {
      "1": "cr_cost = platform.cr_charge × cr_percentage / 100",
      "2": "damage_cost = price × damage_percentage / 100",
      "3": "misc_total = SUM active MiscItem.amount",
      "4": "breakeven = price + package + logistics + ad + addons + misc_total + cr_cost + damage_cost",
      "5": "net_profit = breakeven × profit_percentage / 100",
      "6": "bs_wo_gst = Math.round(breakeven + net_profit)",
      "7": "gst_amt = bs_wo_gst × gst_rate / 100",
      "8": "bank_settlement = bs_wo_gst + gst_amt",
      "9": "platform_bs = bank_settlement + tier.fee"
    },
    "defaults": {
      "damage_percentage": "15%",
      "profit_percentage": "20%",
      "misc_total": "₹12"
    },
    "bidirectional": ["CR%↔CR₹", "Dmg%↔Dmg₹", "Profit%↔Profit₹"],
    "override_priority": "Manual entry > auto-calculated",
    "verified_example": {
      "price": 64, "package": 7, "logistics": 5, "addons": 6,
      "misc": 12, "cr": 35, "damage": 9.6, "gst": 5,
      "breakeven": 138.6, "bs_wo_gst": 166, "bank_settlement": 171
    }
