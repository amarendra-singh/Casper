  "backend": {
    "language": "Python 3.13",
    "framework": "FastAPI 0.111",
    "database": "SQLite (aiosqlite) local, MySQL planned for production",
    "orm": "SQLAlchemy 2.0 async",
    "migrations": "Alembic — current head: 69a98e6c92d7",
    "auth": "JWT Bearer (python-jose), bcrypt passwords",
    "config": "python-decouple (.env file)",
    "run": "cd backend && venv\\Scripts\\activate && uvicorn app.main:app --reload --port 8000",
    "architecture": "Thin routes, fat services. Business logic in services/, not routes/",

    "folder_structure": {
      "app/main.py": "FastAPI entry point, registers all routers",
      "app/core/config.py": "Settings class with lru_cache singleton",
      "app/core/database.py": "Async SQLAlchemy engine + session + Base",
      "app/core/security.py": "bcrypt + JWT create/decode",
      "app/core/dependencies.py": "Auth guards: get_current_user, require_roles",
      "app/models/": "User, Platform, PlatformTier, Vendor, Category, MiscItem, GlobalSettings, HsnCode, Sku, SkuPricing",
      "app/schemas/": "Pydantic schemas for all models + entries.py for batch ops",
      "app/routes/": "auth, users, platforms, vendors, categories, misc_items, global_settings, hsn_codes, skus, entries",
      "app/services/pricing.py": "resolve_pricing_inputs, calculate_pricing",
      "app/services/entries.py": "upsert_row, upsert_batch, get_all_entries"
    },

    "models": {
      "User": "id, name, email, password_hash, role(super_admin|admin|viewer), is_active",
      "Platform": "id, name, cr_charge:float, cr_percentage:float, is_active",
      "PlatformTier": "id, platform_id(FK), tier_name, fee:float",
      "Vendor": "id, name, short_code, is_active",
      "Category": "id, name, is_active",
      "MiscItem": "id, name, amount:float, is_active",
      "GlobalSettings": "id, key, value, description — CLASS NAME IS GlobalSettings (plural)",
      "HsnCode": "id, code, description, gst_rate:float, category, is_custom",
      "Sku": "id, shringar_sku(UPPERCASE,unique), vendor_id(FK), category_id(FK), hsn_code_id(FK), description, is_active",
      "SkuPricing": "id, sku_id(FK), platform_id(FK), price, package, logistics, addons, misc_total, cr_percentage, cr_cost, damage_percentage, damage_cost, gst, breakeven, net_profit_20, bs_wo_gst, bank_settlement, is_active"
    },

    "api_routes": {
      "POST /auth/login": "{email,password} → {access_token, refresh_token, role, name}",
      "POST /auth/refresh": "{refresh_token} → new tokens",
      "GET /auth/me": "current user",
      "POST /auth/change-password": "{current_password, new_password}",
      "GET/POST/PATCH/DELETE /users/": "super_admin write only",
      "GET/POST /platforms/": "includes tiers[]",
      "POST /platforms/{id}/tiers": "add tier",
      "PATCH /platforms/{id}/tiers/{tid}": "update tier",
      "GET/POST/PATCH/DELETE /vendors/": "",
      "GET/POST/PATCH/DELETE /categories/": "",
      "GET/POST/PATCH/DELETE /misc-items/": "",
      "GET /misc-items/total": "{total: float}",
      "GET/PATCH /settings/": "key-value settings",
      "GET /hsn-codes/": "all HSN codes",
      "GET /hsn-codes/search?q=": "search codes",
      "POST /hsn-codes/": "create custom",
      "GET/POST/PATCH/DELETE /skus/": "",
      "POST /pricing/": "create + auto-calculate",
      "PATCH /pricing/{id}": "update + recalculate",
      "GET /pricing/sku/{sku_id}": "all platforms for a SKU",
      "GET /entries/": "all SKUs with latest pricing for SKU page",
      "POST /entries/upsert-batch": "{rows:[...]} create/update multiple rows"
    },

